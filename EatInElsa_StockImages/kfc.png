<!-- BUSINESS PARTICIPATION FORM -->
<section class="biz-section" id="biz-form">
    <div class="biz-title">🤝 Own a Business in Elsa?</div>
    <p style="color:rgba(0,0,0,0.6);text-align:center;margin:0 0 24px;font-size:15px;line-height:1.5;">Get your restaurant in front of every tournament family in town. List your spot and keep the spending local.</p>

    <form class="biz-form" id="bizForm">
        <div class="form-row">
            <div class="form-field">
                <label class="form-label">Business Name *</label>
                <input class="form-input" type="text" name="business_name" placeholder="e.g. Macy's Kitchen" required="">
            </div>
            <div class="form-field">
                <label class="form-label">Your Name *</label>
                <input class="form-input" type="text" name="owner_name" placeholder="First &amp; last name" required="">
            </div>
        </div>
        <div class="form-row">
            <div class="form-field">
                <label class="form-label">Phone Number *</label>
                <input class="form-input" type="tel" name="phone" placeholder="(956) 555-0100" required="">
            </div>
            <div class="form-field">
                <label class="form-label">Email Address</label>
                <input class="form-input" type="email" name="email" placeholder="you@example.com">
            </div>
        </div>
        <div class="form-row">
            <div class="form-field">
                <label class="form-label">Business Address</label>
                <input class="form-input" type="text" name="address" placeholder="Street address in Elsa, TX">
            </div>
            <div class="form-field">
                <label class="form-label">Type of Food</label>
                <select class="form-select" name="food_type">
                    <option value="">Select a category</option>
                    <option>Mexican / Tex-Mex</option>
                    <option>Burgers &amp; American</option>
                    <option>Seafood</option>
                    <option>Pizza</option>
                    <option>Breakfast / Cafe</option>
                    <option>Other</option>
                </select>
            </div>
        </div>
        <div class="form-field" style="margin-bottom:16px;">
            
            
        </div>
        <div class="form-field" style="margin-bottom:20px;">
            <label class="form-label" style="margin-bottom:10px;">Tags that fit your spot:</label>
            <div class="check-grid">
                <label class="check-item"><input type="checkbox" name="tags" value="Quick Stop"> ⚡ Quick Stop</label>
                <label class="check-item"><input type="checkbox" name="tags" value="Team-Friendly"> 👥 Team-Friendly</label>
                <label class="check-item"><input type="checkbox" name="tags" value="Delivery"> 📦 Delivery</label>
                <label class="check-item"><input type="checkbox" name="tags" value="Late Night"> 🌙 Late Night</label>
            </div>
        </div>
        <button type="submit" class="form-submit">🏆 Get My Business Listed</button>
    </form>

    <div class="form-success" id="bizSuccess">
        <div style="font-size:48px;margin-bottom:12px;">🎉</div>
        <div style="font-size:22px;font-weight:800;color:var(--yellow);margin-bottom:8px;">You're in!</div>
        <p style="color:rgba(0,0,0,0.6);font-size:15px;line-height:1.5;">We'll reach out soon to get your listing live. Welcome to the team — let's keep Elsa money in Elsa.</p>
    </div>
</section>

<div class="bottom-spacer"></div>

<!-- ===== FLOATING PLAY BUTTON ===== -->
<button class="float-btn" id="floatBtn">
    Find Food Nearby →
</button>

