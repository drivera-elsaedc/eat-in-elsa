<!DOCTYPE html><html lang="en"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8"><style rel="stylesheet" type="text/css">@charset "utf-8";

* { margin: 0px; padding: 0px; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

:root { --black: #111111; --white: #FFFFFF; --yellow: #FFC72C; --navy: #0F1F3D; --cream: #FFF4D6; --red: #FF4D4D; --green: #2ECC71; --blue: #35A7FF; --orange: #FF9F1C; }

html, body { font-family: Nunito, sans-serif; background: var(--cream); color: var(--black); overflow-x: hidden; }

.top-bar { position: fixed; top: 0px; left: 0px; right: 0px; z-index: 100; background: var(--black); display: flex; align-items: center; justify-content: space-between; padding: 10px 16px; height: 56px; }

.top-bar-wordmark { font-family: Nunito, sans-serif; font-weight: 900; font-size: 17px; color: var(--yellow); letter-spacing: 0.06em; }

.top-bar-btn { background: var(--yellow); color: var(--black); border: none; border-radius: 20px; padding: 8px 16px; font-family: Nunito, sans-serif; font-weight: 900; font-size: 13px; cursor: pointer; white-space: nowrap; }

.hero { min-height: 100svh; padding: 56px 24px 40px; background: var(--cream); display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; position: relative; overflow: hidden; }

.hero::before { content: ""; position: absolute; width: 360px; height: 360px; background: rgba(255, 199, 44, 0.18); transform: rotate(45deg); border-radius: 16px; bottom: -100px; right: -100px; }

.hero::after { content: ""; position: absolute; width: 220px; height: 220px; background: rgba(255, 199, 44, 0.12); transform: rotate(45deg); border-radius: 10px; top: 80px; left: -70px; }

.hero-logo { width: 280px; max-width: 85%; margin-bottom: 24px; position: relative; z-index: 1; }

.hero-headline { color: var(--black); font-size: 26px; font-weight: 900; line-height: 1.25; margin-bottom: 12px; position: relative; z-index: 1; }

.hero-sub { color: rgba(0, 0, 0, 0.5); font-size: 15px; font-weight: 600; max-width: 290px; line-height: 1.6; margin-bottom: 32px; position: relative; z-index: 1; }

.hero-btns { display: flex; flex-direction: column; gap: 12px; width: 100%; max-width: 290px; position: relative; z-index: 1; }

.btn-primary { background: var(--yellow); color: var(--black); border: none; border-radius: 14px; padding: 17px 24px; font-family: Nunito, sans-serif; font-weight: 900; font-size: 16px; cursor: pointer; width: 100%; letter-spacing: 0.01em; }

.btn-outline { background: transparent; color: var(--black); border: 2px solid rgba(0, 0, 0, 0.2); border-radius: 14px; padding: 16px 24px; font-family: Nunito, sans-serif; font-weight: 800; font-size: 16px; cursor: pointer; width: 100%; }

.hero-pills { margin-top: 28px; display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; position: relative; z-index: 1; }

.hero-pill { background: rgba(0, 0, 0, 0.07); color: rgba(0, 0, 0, 0.5); font-size: 12px; font-weight: 700; padding: 6px 12px; border-radius: 20px; }

.hero-pill span { color: rgb(196, 144, 0); }

.section { padding: 32px 0px 8px; }

.section-header { padding: 0px 20px; margin-bottom: 16px; display: flex; align-items: baseline; justify-content: space-between; }

.section-title { font-size: 22px; font-weight: 900; color: var(--black); }

.section-sub { font-size: 12px; font-weight: 700; color: rgba(0, 0, 0, 0.35); }

.deals-strip { display: flex; gap: 12px; overflow-x: auto; padding: 4px 20px 20px; scroll-snap-type: x mandatory; scrollbar-width: none; }

.deals-strip::-webkit-scrollbar { display: none; }

.deal-card { flex: 0 0 215px; scroll-snap-align: start; background: var(--white); border-radius: 18px; overflow: hidden; box-shadow: rgba(0, 0, 0, 0.09) 0px 2px 16px; }

.deal-card-top { background: var(--navy); padding: 16px; position: relative; min-height: 80px; }

.deal-card-badge { background: var(--yellow); color: var(--black); font-size: 9px; font-weight: 900; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 8px; border-radius: 20px; display: inline-block; margin-bottom: 8px; }

.deal-card-restaurant { color: var(--white); font-size: 15px; font-weight: 900; line-height: 1.25; padding-right: 32px; }

.deal-card-ball { position: absolute; right: 14px; bottom: 14px; font-size: 26px; opacity: 0.25; }

.deal-card-body { padding: 14px 16px 16px; }

.deal-offer { font-size: 15px; font-weight: 900; color: var(--black); line-height: 1.3; margin-bottom: 6px; }

.deal-redeem { font-size: 11px; font-weight: 700; color: rgba(0, 0, 0, 0.35); margin-bottom: 14px; }

.deal-btn { display: block; width: 100%; background: var(--yellow); color: var(--black); border: none; border-radius: 10px; padding: 10px; font-family: Nunito, sans-serif; font-weight: 900; font-size: 13px; cursor: pointer; text-align: center; text-decoration: none; }

.float-btn { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); z-index: 99; background: var(--yellow); color: var(--black); border: none; border-radius: 30px; padding: 16px 28px; font-family: Nunito, sans-serif; font-weight: 900; font-size: 15px; cursor: pointer; box-shadow: rgba(255, 199, 44, 0.55) 0px 4px 24px; display: flex; align-items: center; gap: 8px; white-space: nowrap; animation: 2.8s ease-in-out 0s infinite normal none running floatPulse; }

@keyframes floatPulse { 
  0%, 100% { box-shadow: rgba(255, 199, 44, 0.5) 0px 4px 24px; transform: translateX(-50%) translateY(0px); }
  50% { box-shadow: rgba(255, 199, 44, 0.75) 0px 10px 36px; transform: translateX(-50%) translateY(-4px); }
}

.game-overlay { position: fixed; inset: 0px; z-index: 200; background: var(--navy); display: flex; flex-direction: column; align-items: center; overflow-y: auto; transform: translateY(100%); transition: transform 0.42s cubic-bezier(0.34, 1.4, 0.64, 1); }

.game-overlay.open { transform: translateY(0px); }

.game-close { position: fixed; top: 16px; right: 16px; background: rgba(255, 255, 255, 0.12); border: none; color: white; width: 38px; height: 38px; border-radius: 50%; font-size: 16px; cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 10; font-weight: 700; }

.game-inner { width: 100%; max-width: 420px; padding: 72px 24px 100px; display: flex; flex-direction: column; align-items: center; }

.game-logo-small { height: 34px; margin-bottom: 28px; background: white; border-radius: 8px; padding: 4px 12px; }

#gamePlay { width: 100%; display: flex; flex-direction: column; align-items: center; }

.game-title { font-family: Pacifico, cursive; font-size: 42px; color: var(--yellow); text-align: center; line-height: 1.1; margin-bottom: 6px; text-shadow: rgba(0, 0, 0, 0.35) 3px 4px 0px; }

.game-tagline { font-size: 13px; font-weight: 700; color: rgba(255, 255, 255, 0.4); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 32px; text-align: center; }

.baseball-wrap { margin-bottom: 28px; }

.baseball { width: 90px; height: 90px; border-radius: 50%; background: radial-gradient(circle at 35% 35%, rgb(253, 250, 243), rgb(237, 232, 216)); box-shadow: rgba(0, 0, 0, 0.18) -3px -3px 10px inset, rgba(0, 0, 0, 0.35) 0px 6px 24px; position: relative; overflow: hidden; }

.baseball::before { content: ""; position: absolute; width: 28px; height: 56px; border-width: 2.5px; border-style: solid; border-color: rgb(204, 51, 51) transparent transparent rgb(204, 51, 51); border-image: initial; border-radius: 50%; top: 18px; left: 18px; transform: rotate(12deg); }

.baseball::after { content: ""; position: absolute; width: 28px; height: 56px; border-width: 2.5px; border-style: solid; border-color: transparent rgb(204, 51, 51) rgb(204, 51, 51) transparent; border-image: initial; border-radius: 50%; top: 16px; right: 18px; transform: rotate(12deg); }

.game-prompt { font-size: 20px; font-weight: 900; color: var(--white); margin-bottom: 22px; text-align: center; }

.pitch-buttons { width: 100%; display: flex; flex-direction: column; gap: 12px; margin-bottom: 32px; }

.pitch-btn { width: 100%; background: rgba(255, 255, 255, 0.07); border: 2px solid rgba(255, 255, 255, 0.12); border-radius: 16px; padding: 18px 20px; color: var(--white); font-family: Nunito, sans-serif; font-weight: 900; font-size: 17px; cursor: pointer; display: flex; align-items: center; gap: 14px; transition: background 0.12s, border-color 0.12s, transform 0.1s; text-align: left; }

.pitch-btn:active { transform: scale(0.97); }

.pitch-btn.correct { background: rgba(46, 204, 113, 0.18); border-color: var(--green); color: var(--green); }

.pitch-btn.wrong { background: rgba(255, 77, 77, 0.18); border-color: var(--red); color: var(--red); }

.pitch-btn.show-correct { background: rgba(46, 204, 113, 0.1); border-color: rgba(46, 204, 113, 0.35); }

.pitch-icon { font-size: 24px; }

.pitch-name { display: block; }

.pitch-desc { display: block; font-size: 12px; font-weight: 600; opacity: 0.45; margin-top: 2px; }

.strike-row { display: flex; align-items: center; gap: 10px; }

.strike-label { font-size: 11px; font-weight: 800; color: rgba(255, 255, 255, 0.35); letter-spacing: 0.12em; text-transform: uppercase; margin-right: 4px; }

.s-ball { font-size: 22px; transition: 0.25s; filter: grayscale(1) brightness(0.35); }

.s-ball.out { filter: none; animation: 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) 0s 1 normal none running popIn; }

#winState { display: none; flex-direction: column; align-items: center; text-align: center; width: 100%; }

#winState.show { display: flex; animation: 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) 0s 1 normal none running popIn; }

.win-emoji { font-size: 56px; margin-bottom: 8px; animation: 0.7s ease 0s infinite alternate none running bounceY; }

.win-title { font-family: Pacifico, cursive; font-size: 50px; color: var(--yellow); text-shadow: rgba(0, 0, 0, 0.3) 3px 4px 0px; margin-bottom: 6px; line-height: 1; }

.win-sub { font-size: 15px; font-weight: 700; color: rgba(255, 255, 255, 0.5); margin-bottom: 24px; }

@keyframes bounceY { 
  0% { transform: translateY(0px); }
  100% { transform: translateY(-10px); }
}

.coupon-card { background: var(--white); border-radius: 20px; overflow: hidden; width: 100%; max-width: 320px; box-shadow: rgba(0, 0, 0, 0.45) 0px 10px 50px; margin-bottom: 20px; }

.coupon-top { background: var(--yellow); padding: 16px 20px; display: flex; align-items: center; justify-content: space-between; }

.coupon-top-label { font-size: 10px; font-weight: 900; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(0, 0, 0, 0.55); margin-bottom: 4px; }

.coupon-top-name { font-size: 17px; font-weight: 900; color: var(--black); }

.coupon-top-icon { font-size: 28px; }

.coupon-dashes { border-top: 2px dashed rgba(0, 0, 0, 0.1); margin: 0px; }

.coupon-body { padding: 18px 20px 20px; }

.coupon-offer { font-size: 22px; font-weight: 900; color: var(--black); line-height: 1.25; margin-bottom: 12px; }

.coupon-instructions { font-size: 13px; font-weight: 700; color: rgba(0, 0, 0, 0.45); background: rgba(0, 0, 0, 0.04); padding: 10px 14px; border-radius: 10px; margin-bottom: 16px; }

.coupon-footer { display: flex; justify-content: space-between; align-items: center; }

.coupon-exp { font-size: 11px; font-weight: 700; color: rgba(0, 0, 0, 0.3); }

.coupon-dir-btn { background: var(--black); color: var(--white); border: none; border-radius: 10px; padding: 9px 14px; font-family: Nunito, sans-serif; font-weight: 800; font-size: 13px; cursor: pointer; }

.play-again-btn { background: rgba(255, 255, 255, 0.1); color: var(--white); border: 2px solid rgba(255, 255, 255, 0.2); border-radius: 14px; padding: 14px 32px; font-family: Nunito, sans-serif; font-weight: 800; font-size: 15px; cursor: pointer; }

#outState { display: none; flex-direction: column; align-items: center; text-align: center; }

#outState.show { display: flex; animation: 0.4s cubic-bezier(0.34, 1.4, 0.64, 1) 0s 1 normal none running popIn; }

.out-emoji { font-size: 64px; margin-bottom: 12px; }

.out-title { font-family: Pacifico, cursive; font-size: 46px; color: var(--red); text-shadow: rgba(0, 0, 0, 0.3) 3px 4px 0px; margin-bottom: 12px; }

.out-msg { font-size: 16px; font-weight: 700; color: rgba(255, 255, 255, 0.55); max-width: 240px; line-height: 1.5; margin-bottom: 30px; }

.try-again-btn { background: var(--yellow); color: var(--black); border: none; border-radius: 14px; padding: 17px 44px; font-family: Nunito, sans-serif; font-weight: 900; font-size: 18px; cursor: pointer; }

@keyframes popIn { 
  0% { transform: scale(0.8); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes shake { 
  0%, 100% { transform: translateX(0px); }
  20% { transform: translateX(-8px); }
  40% { transform: translateX(8px); }
  60% { transform: translateX(-5px); }
  80% { transform: translateX(5px); }
}

.shake { animation: 0.38s ease 0s 1 normal none running shake; }

.red-flash { position: fixed; inset: 0px; background: rgba(255, 77, 77, 0.14); pointer-events: none; z-index: 300; opacity: 0; transition: opacity 0.08s; }

.red-flash.on { opacity: 1; }

.rest-strip { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; padding: 4px 16px 24px; }

.rest-card { background: var(--white); border-radius: 16px; overflow: hidden; box-shadow: rgba(0, 0, 0, 0.09) 0px 2px 12px; display: flex; flex-direction: column; transition: transform 0.15s, box-shadow 0.15s; }

.rest-card:active { transform: scale(0.97); box-shadow: rgba(0, 0, 0, 0.08) 0px 1px 6px; }

.rest-card-photo { height: 110px; position: relative; flex-shrink: 0; overflow: hidden; }

.rest-card-top { background: var(--white); padding: 8px 10px 6px; position: relative; }

.rest-card-name { color: var(--black); font-size: 13px; font-weight: 900; line-height: 1.2; margin-bottom: 2px; padding-right: 36px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

.rest-card-type { color: rgba(0, 0, 0, 0.4); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; }

.local-badge { position: absolute; top: 7px; right: 7px; background: var(--yellow); color: var(--black); font-size: 8px; font-weight: 900; letter-spacing: 0.07em; text-transform: uppercase; padding: 2px 6px; border-radius: 20px; z-index: 1; }

.rest-card-body { padding: 8px 10px 10px; flex: 1 1 0%; display: flex; flex-direction: column; gap: 6px; }

.rest-distance { font-size: 11px; font-weight: 700; color: rgba(0, 0, 0, 0.38); }

.rest-tags { display: flex; flex-wrap: nowrap; gap: 4px; overflow: hidden; }

.rest-tag { background: rgba(0, 0, 0, 0.06); color: rgba(0, 0, 0, 0.45); font-size: 9px; font-weight: 800; padding: 2px 6px; border-radius: 20px; }

.rest-btns { display: flex; gap: 6px; margin-top: auto; }

.btn-dir { flex: 1 1 0%; background: var(--black); color: var(--white); border: none; border-radius: 8px; padding: 7px 4px; white-space: nowrap; font-family: Nunito, sans-serif; font-weight: 800; font-size: 12px; cursor: pointer; }

.btn-call { white-space: nowrap; flex: 1 1 0%; background: transparent; color: var(--black); border: 2px solid rgba(0, 0, 0, 0.14); border-radius: 10px; padding: 9px 6px; font-family: Nunito, sans-serif; font-weight: 800; font-size: 12px; cursor: pointer; }

.btn-deal { width: 100%; background: var(--yellow); color: var(--black); border: none; border-radius: 10px; padding: 9px 6px; font-family: Nunito, sans-serif; font-weight: 900; font-size: 12px; cursor: pointer; }

.section-accent { display: inline-block; width: 32px; height: 3px; border-radius: 2px; margin-bottom: 6px; }

.section-tagline { padding: 4px 20px 14px; font-size: 13px; font-weight: 700; color: rgba(0, 0, 0, 0.42); line-height: 1.55; }

.mood-wrap { padding: 0px 20px 28px; }

.mood-label { font-size: 11px; font-weight: 800; color: rgba(0, 0, 0, 0.32); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 10px; }

.mood-tiles { display: flex; gap: 10px; }

.mood-tile { flex: 1 1 0%; background: var(--white); border: 2px solid rgba(0, 0, 0, 0.07); border-radius: 16px; padding: 16px 8px; display: flex; flex-direction: column; align-items: center; gap: 6px; font-family: Nunito, sans-serif; font-weight: 800; font-size: 12px; color: var(--black); cursor: pointer; transition: 0.15s; box-shadow: rgba(0, 0, 0, 0.06) 0px 2px 10px; }

.mood-tile:active { transform: scale(0.95); background: var(--cream); }

.mood-tile .me { font-size: 24px; }

.status-inline { display: block; font-size: 10px; font-weight: 800; margin-top: 4px; letter-spacing: 0.04em; }

.status-open { color: rgb(24, 165, 88); }

.status-closed { color: rgba(0, 0, 0, 0.35); }

.countdown-badge { position: absolute; bottom: 10px; right: 12px; font-size: 10px; font-weight: 800; color: rgba(255, 255, 255, 0.45); }

.share-btn { background: rgba(255, 255, 255, 0.08); color: rgba(255, 255, 255, 0.65); border: 2px solid rgba(255, 255, 255, 0.15); border-radius: 14px; padding: 13px 24px; font-family: Nunito, sans-serif; font-weight: 800; font-size: 14px; cursor: pointer; width: 100%; max-width: 320px; margin-bottom: 12px; }

#grandSlamState { display: none; flex-direction: column; align-items: center; text-align: center; width: 100%; }

#grandSlamState.show { display: flex; animation: 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) 0s 1 normal none running popIn; }

.gs-emoji { font-size: 68px; margin-bottom: 8px; animation: 0.7s ease 0s infinite alternate none running bounceY; }

.gs-title { font-family: Pacifico, cursive; font-size: 44px; color: var(--yellow); text-shadow: rgba(0, 0, 0, 0.3) 3px 4px 0px; margin-bottom: 6px; line-height: 1; }

.gs-sub { font-size: 15px; font-weight: 700; color: rgba(255, 255, 255, 0.5); margin-bottom: 24px; }

.biz-section { background: var(--cream); padding: 40px 20px 56px; margin-top: 8px; border-top: 4px solid var(--yellow); }

.biz-eyebrow { font-size: 11px; font-weight: 800; color: var(--yellow); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 8px; }

.biz-title { font-family: Pacifico, cursive; font-size: 30px; color: var(--black); line-height: 1.2; margin-bottom: 10px; text-shadow: rgba(255, 199, 44, 0.4) 1px 2px 0px; }

.biz-sub { font-size: 14px; font-weight: 700; color: rgba(0, 0, 0, 0.55); line-height: 1.6; margin-bottom: 28px; }

.biz-form { display: flex; flex-direction: column; gap: 14px; }

.form-row { display: flex; gap: 12px; }

.form-field { display: flex; flex-direction: column; gap: 5px; flex: 1 1 0%; }

.form-label { font-size: 10px; font-weight: 800; color: rgba(0, 0, 0, 0.45); letter-spacing: 0.1em; text-transform: uppercase; }

.form-input, .form-textarea, .form-select { background: var(--white); border: 2px solid rgba(0, 0, 0, 0.12); border-radius: 12px; padding: 13px 14px; font-family: Nunito, sans-serif; font-size: 14px; font-weight: 700; color: var(--black); width: 100%; outline: none; transition: border-color 0.15s; appearance: none; }

.form-input::placeholder, .form-textarea::placeholder { color: rgba(0, 0, 0, 0.25); }

.form-input:focus, .form-textarea:focus, .form-select:focus { border-color: var(--yellow); }

.form-textarea { resize: none; height: 88px; }

.form-select option { background: var(--white); color: var(--black); }

.check-section-label { font-size: 10px; font-weight: 800; color: rgba(0, 0, 0, 0.45); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 2px; }

.check-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

.check-item { display: flex; align-items: center; gap: 9px; cursor: pointer; }

.check-item input[type="checkbox"] { width: 18px; height: 18px; accent-color: var(--yellow); cursor: pointer; flex-shrink: 0; }

.check-item span { font-size: 13px; font-weight: 700; color: rgba(0, 0, 0, 0.7); }

.form-divider { border-right: none; border-bottom: none; border-left: none; border-image: initial; border-top: 1px solid rgba(255, 255, 255, 0.08); margin: 2px 0px; }

.form-submit { background: var(--yellow); color: var(--black); border: none; border-radius: 14px; padding: 17px; font-family: Nunito, sans-serif; font-weight: 900; font-size: 16px; cursor: pointer; width: 100%; margin-top: 4px; }

.form-note { font-size: 11px; font-weight: 700; color: rgba(255, 255, 255, 0.2); text-align: center; line-height: 1.5; padding: 0px 8px; }

.form-success { display: none; flex-direction: column; align-items: center; text-align: center; gap: 14px; padding: 20px 0px; }

.form-success.show { display: flex; animation: 0.4s ease 0s 1 normal none running popIn; }

.form-success-emoji { font-size: 60px; }

.form-success-title { font-family: Pacifico, cursive; font-size: 30px; color: var(--yellow); text-shadow: rgba(0, 0, 0, 0.25) 2px 3px 0px; }

.form-success-msg { font-size: 14px; font-weight: 700; color: rgba(255, 255, 255, 0.5); max-width: 280px; line-height: 1.6; }

.bottom-spacer { height: 90px; }</style>
    
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Eat in Elsa</title>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&amp;family=Nunito:wght@400;600;700;800;900&amp;display=swap" rel="stylesheet">
    
</head>
<body>

<!-- Red flash for strikes -->
<div class="red-flash" id="redFlash"></div>

<!-- ===== TOP BAR ===== -->
<header class="top-bar">
    <span class="top-bar-wordmark">EAT IN ELSA</span>
    <button class="top-bar-btn">Find Food Nearby →</button>
</header>

<!-- ===== HERO ===== -->
<section class="hero">
    <img src="data:image/png;base64," alt="Eat in Elsa" class="hero-logo">
    <h1 class="hero-headline">Your game-day dining<br>guide for Elsa.</h1>
    <p class="hero-sub">Visiting for a tournament? Find local food, family-friendly spots, and great restaurants close to the fields.</p>
    <div class="hero-btns">
        <button class="btn-primary">Find Food Nearby →</button>
        <button class="btn-outline">Find Food Nearby →</button>
    </div>
    <div class="hero-pills">
        
        <span class="hero-pill">Family-friendly</span>
        <span class="hero-pill">Minutes away</span>
    </div>
</section>

<!-- ===== MOOD SELECTOR ===== -->
<div class="mood-wrap">
    <p class="mood-label">What do you need right now?</p>
    <div class="mood-tiles">
        <button class="mood-tile">
            <span class="me">⚡</span>Fast &amp; Easy
        </button>
        <button class="mood-tile">
